    <integer-array name="config_udfps_sensor_props">
        <item>540</item> <!-- sensorLocationX -->
        <item>2164</item> <!-- sensorLocationY -->
        <item>91</item> <!-- sensorRadius -->
    </integer-array>

    <!-- Whether or not wcg (wide color gamut) should be enabled on this device,
